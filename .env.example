# ─── Adafruit IO ─────────────────────────────────────────────────────
# Get your key from: https://io.adafruit.com → My Key
EXPO_PUBLIC_AIO_USERNAME=your_adafruit_username
EXPO_PUBLIC_AIO_KEY=your_adafruit_io_key

# ─── Twilio ───────────────────────────────────────────────────────────
# Get from: https://console.twilio.com
EXPO_PUBLIC_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_TWILIO_AUTH_TOKEN=your_auth_token
EXPO_PUBLIC_TWILIO_FROM_PHONE=+1xxxxxxxxxx
EXPO_PUBLIC_TWILIO_ALERT_PHONE=+91xxxxxxxxxx

# ─── Firebase ─────────────────────────────────────────────────────────
# Get from: https://console.firebase.google.com → Project Settings
# Fill in firebaseConfig.js with your values
